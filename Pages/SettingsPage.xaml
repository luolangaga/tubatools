<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TubaWinUi3.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.62" />
            <Setter Property="Margin" Value="0,24,0,6" />
        </Style>
        <Style x:Key="IconBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <RelativePanel HorizontalAlignment="Stretch">
                <StackPanel
                    x:Name="ContentPanel"
                    RelativePanel.AlignHorizontalCenterWithPanel="True"
                    RelativePanel.AlignLeftWithPanel="True"
                    RelativePanel.AlignRightWithPanel="True"
                    MaxWidth="1000"
                    Spacing="2"
                    Padding="40,28,40,48">
                    <StackPanel.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </StackPanel.Transitions>

                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="设置" />
                    <TextBlock
                        Opacity="0.72"
                        Margin="0,0,0,16"
                        Text="管理应用外观、更新及查看关于信息。" />

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="关于" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Image
                            Width="56"
                            Height="56"
                            Source="ms-appx:///Assets/Square150x150Logo.png"
                            Stretch="UniformToFill" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="图吧工具箱" />
                            <TextBlock Opacity="0.68" Text="基于 WinUI 3 构建的 PC 硬件工具集合" />
                            <TextBlock
                                x:Name="VersionText"
                                Opacity="0.52"
                                FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="常规" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE895;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="检查更新" />
                            <TextBlock
                                x:Name="UpdateStatusText"
                                Opacity="0.68"
                                FontSize="13"
                                Text="点击检查是否有新版本" />
                        </StackPanel>

                        <Button
                            x:Name="CheckUpdateButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="CheckUpdateButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE895;" />
                                <TextBlock Text="检查更新" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE790;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="应用主题" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="选择浅色、深色或跟随系统" />
                        </StackPanel>

                        <ComboBox
                            x:Name="ThemeComboBox"
                            Grid.Column="2"
                            MinWidth="120"
                            SelectionChanged="ThemeComboBox_SelectionChanged" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE8FD;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="简洁列表模式" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="原版图吧工具箱的样式" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="CompactModeToggle"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Toggled="CompactModeToggle_Toggled" />
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="外观" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE91B;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="背景图片" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="导入图片作为主页面背景" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button
                                    x:Name="ClearBgButton"
                                    Padding="10,6"
                                    Click="ClearBgButton_Click"
                                    Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="12" Glyph="&#xE711;" />
                                        <TextBlock Text="清除" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="ImportBgButton"
                                    Padding="10,6"
                                    Click="ImportBgButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="12" Glyph="&#xE898;" />
                                        <TextBlock Text="导入图片" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border
                            Grid.Row="1"
                            x:Name="BgPreviewBorder"
                            Padding="0,1"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                            Visibility="Collapsed" />

                        <Grid Grid.Row="2" ColumnSpacing="16" x:Name="BgPreviewPanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="120"
                                Height="68"
                                CornerRadius="6"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                                <Image
                                    x:Name="BgPreviewImage"
                                    Stretch="UniformToFill" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <TextBlock
                                    x:Name="BgFileNameText"
                                    FontSize="13"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1" />
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Opacity="0.68" VerticalAlignment="Center" Text="透明度" />
                                    <Slider
                                        x:Name="BgOpacitySlider"
                                        Width="160"
                                        ValueChanged="BgOpacitySlider_ValueChanged" />
                                    <TextBlock
                                        x:Name="BgOpacityText"
                                        FontSize="12"
                                        Opacity="0.68"
                                        VerticalAlignment="Center"
                                        Text="15%" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="工具来源" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE90F;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="图吧工具箱" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="本软件所集成的全部硬件检测与测试工具，均来源于「图吧工具箱」项目。" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://www.tbtool.cn"
                            Content="访问官网" />
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="作者" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <PersonPicture
                            x:Name="AuthorAvatar"
                            Width="44"
                            Height="44" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="哈基毅" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="开发者 / Designer" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://github.com/luolangaga">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE8F1;" />
                                <TextBlock Text="GitHub" />
                            </StackPanel>
                        </HyperlinkButton>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="链接" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE71B;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="官方网站" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="tubawinui3.cn" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://tubawinui3.cn"
                            Content="访问官网" />
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="开源引用" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE946;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="Windows App SDK (WinUI 3)" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="Microsoft.WindowsAppSDK" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://github.com/microsoft/WindowsAppSDK"
                            Content="GitHub" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE946;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="Win2D" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="Microsoft.Graphics.Win2D" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://github.com/microsoft/Win2D"
                            Content="GitHub" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE946;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="System.Drawing.Common" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="图标提取与图像处理" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://learn.microsoft.com/dotnet/core/compatibility/core-libraries/6.0/system-drawing-common-windows-only"
                            Content="Docs" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE946;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="System.Management" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="WMI 硬件信息查询" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://learn.microsoft.com/dotnet/api/system.management"
                            Content="Docs" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE946;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="Microsoft.Windows.SDK.BuildTools" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="Windows SDK 构建工具" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://www.nuget.org/packages/Microsoft.Windows.SDK.BuildTools"
                            Content="NuGet" />
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="开发者" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE783;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="测试异常页面" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="手动抛出一个未处理异常，用于验证全局错误页面。" />
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="ThrowErrorButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE783;" />
                                <TextBlock Text="抛出异常" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </RelativePanel>
    </ScrollViewer>
    </Grid>
</Page>
