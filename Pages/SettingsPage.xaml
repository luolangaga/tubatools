<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TubaWinUi3.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.62" />
            <Setter Property="Margin" Value="0,24,0,6" />
        </Style>
        <Style x:Key="IconBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Storyboard x:Name="DrawerOpenStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="DrawerOverlayBackground"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.2" />
            <DoubleAnimation
                Storyboard.TargetName="DrawerPanelTransform"
                Storyboard.TargetProperty="X"
                From="420"
                To="0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Name="DrawerCloseStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="DrawerOverlayBackground"
                Storyboard.TargetProperty="Opacity"
                From="1"
                To="0"
                Duration="0:0:0.15" />
            <DoubleAnimation
                Storyboard.TargetName="DrawerPanelTransform"
                Storyboard.TargetProperty="X"
                From="0"
                To="420"
                Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <RelativePanel HorizontalAlignment="Stretch">
                <StackPanel
                    x:Name="ContentPanel"
                    RelativePanel.AlignHorizontalCenterWithPanel="True"
                    RelativePanel.AlignLeftWithPanel="True"
                    RelativePanel.AlignRightWithPanel="True"
                    MaxWidth="1000"
                    Spacing="2"
                    Padding="40,28,40,48">
                    <StackPanel.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </StackPanel.Transitions>

                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="设置" />
                    <TextBlock
                        Opacity="0.72"
                        Margin="0,0,0,16"
                        Text="管理应用外观、更新及查看关于信息。" />

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="关于" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Image
                            x:Name="SettingsGifImage"
                            Width="56"
                            Height="56"
                            Stretch="UniformToFill" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="图吧工具箱" />
                            <TextBlock Opacity="0.68" Text="基于 WinUI 3 构建的 PC 硬件工具集合" />
                            <TextBlock
                                x:Name="VersionText"
                                Opacity="0.52"
                                FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="常规" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE895;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="检查更新" />
                            <TextBlock
                                x:Name="UpdateStatusText"
                                Opacity="0.68"
                                FontSize="13"
                                Text="点击检查是否有新版本" />
                        </StackPanel>

                        <Button
                            x:Name="CheckUpdateButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="CheckUpdateButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE895;" />
                                <TextBlock Text="检查更新" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE790;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="应用主题" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="选择浅色、深色或跟随系统" />
                        </StackPanel>

                        <ComboBox
                            x:Name="ThemeComboBox"
                            Grid.Column="2"
                            MinWidth="120"
                            SelectionChanged="ThemeComboBox_SelectionChanged" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE8FD;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="简洁列表模式" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="原版图吧工具箱的样式" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="CompactModeToggle"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Toggled="CompactModeToggle_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xEB3F;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="快速模式" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="禁用所有动画，提升响应速度" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="FastModeToggle"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Toggled="FastModeToggle_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE8B9;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="截图水印" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="硬件信息截图时在右下角添加水印" />
                            </StackPanel>

                            <ToggleSwitch
                                x:Name="WatermarkToggle"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Toggled="WatermarkToggle_Toggled" />
                        </Grid>

                        <Border
                            Grid.Row="1"
                            x:Name="WatermarkDivider"
                            Padding="0,1"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Grid.Row="2" ColumnSpacing="16" x:Name="WatermarkDetailPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE8D2;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="水印文字" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="自定义截图水印显示的文字" />
                            </StackPanel>

                            <TextBox
                                x:Name="WatermarkTextBox"
                                Grid.Column="2"
                                MinWidth="160"
                                MaxWidth="240"
                                PlaceholderText="图吧工具箱"
                                TextChanged="WatermarkTextBox_TextChanged" />
                        </Grid>

                        <Grid Grid.Row="3" ColumnSpacing="16" x:Name="WatermarkFontPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE9F5;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="水印字体" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="自定义截图水印使用的字体" />
                            </StackPanel>

                            <ComboBox
                                x:Name="WatermarkFontComboBox"
                                Grid.Column="2"
                                MinWidth="160"
                                SelectionChanged="WatermarkFontComboBox_SelectionChanged" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE784;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="记住窗口位置和大小" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="关闭后下次启动将居中显示，避免多显示器断开后窗口位置异常" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="RememberWindowToggle"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Toggled="RememberWindowToggle_Toggled" />
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="外观" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE91B;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="背景图片" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="导入图片作为主页面背景" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button
                                    x:Name="ClearBgButton"
                                    Padding="10,6"
                                    Click="ClearBgButton_Click"
                                    Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="12" Glyph="&#xE711;" />
                                        <TextBlock Text="清除" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="ImportBgButton"
                                    Padding="10,6"
                                    Click="ImportBgButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="12" Glyph="&#xE898;" />
                                        <TextBlock Text="导入图片" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border
                            Grid.Row="1"
                            x:Name="BgPreviewBorder"
                            Padding="0,1"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                            Visibility="Collapsed" />

                        <Grid Grid.Row="2" ColumnSpacing="16" x:Name="BgPreviewPanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="120"
                                Height="68"
                                CornerRadius="6"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                                <Image
                                    x:Name="BgPreviewImage"
                                    Stretch="UniformToFill" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <TextBlock
                                    x:Name="BgFileNameText"
                                    FontSize="13"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1" />
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Opacity="0.68" VerticalAlignment="Center" Text="透明度" />
                                    <Slider
                                        x:Name="BgOpacitySlider"
                                        Width="160"
                                        ValueChanged="BgOpacitySlider_ValueChanged" />
                                    <TextBlock
                                        x:Name="BgOpacityText"
                                        FontSize="12"
                                        Opacity="0.68"
                                        VerticalAlignment="Center"
                                        Text="15%" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="自定义工具" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE8E5;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="导入自定义工具" />
                            <TextBlock
                                x:Name="ImportToolStatusText"
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="从压缩包导入工具，选择主程序、架构版本、简介和分类。" />
                        </StackPanel>

                        <Button
                            x:Name="ImportToolButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="ImportToolButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE8E5;" />
                                <TextBlock Text="导入" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE896;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="导出当前软件" />
                            <TextBlock
                                x:Name="ExportAppStatusText"
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="把当前程序目录、工具和元数据打包成可分发压缩包。" />
                        </StackPanel>

                        <Button
                            x:Name="ExportAppButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="ExportAppButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE896;" />
                                <TextBlock Text="导出" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="工具来源" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE90F;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="图吧工具箱" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="本软件所集成的全部硬件检测与测试工具，均来源于「图吧工具箱」项目。" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://www.tbtool.cn"
                            Content="访问官网" />
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="作者" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <PersonPicture
                            x:Name="AuthorAvatar"
                            Width="44"
                            Height="44" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="哈基毅" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="开发者 / Designer" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://github.com/luolangaga">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE8F1;" />
                                <TextBlock Text="GitHub" />
                            </StackPanel>
                        </HyperlinkButton>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="链接" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE71B;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="官方网站" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="tubawinui3.cn" />
                        </StackPanel>

                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            NavigateUri="https://tubawinui3.cn"
                            Content="访问官网" />
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="开源引用" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE946;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="开源引用" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="查看本软件使用的所有开源项目" />
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="OpenSourceButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE890;" />
                                <TextBlock Text="查看全部" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="开发者" />

                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE783;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="测试异常页面" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="手动抛出一个未处理异常，用于验证全局错误页面。" />
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="ThrowErrorButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE783;" />
                                <TextBlock Text="抛出异常" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </RelativePanel>
    </ScrollViewer>

    <Grid
        x:Name="DrawerOverlay"
        Visibility="Collapsed">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="DrawerOverlayBackground"
            Grid.ColumnSpan="2"
            Background="#99000000"
            Opacity="0"
            Tapped="DrawerOverlayBackground_Tapped" />

        <Border
            x:Name="DrawerPanel"
            Grid.Column="1"
            Width="420"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1,0,0,0"
            RenderTransformOrigin="0,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="DrawerPanelTransform" X="420" />
            </Border.RenderTransform>
