<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="TubaWinUi3.Pages.ToolDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <Grid x:Name="DialogRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Rectangle
            x:Name="SmokeLayer"
            Fill="{ThemeResource SmokeFillColorDefaultBrush}"
            Opacity="0"
            Grid.RowSpan="3" />

        <Border
            x:Name="ContentPanel"
            Grid.Row="1"
            Grid.RowSpan="2"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
            CornerRadius="8,8,0,0"
            VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Padding="16,12,16,0">
                    <Button
                        x:Name="BackButton"
                        Width="36"
                        Height="36"
                        Padding="0"
                        Click="BackButton_Click"
                        ToolTipService.ToolTip="返回">
                        <FontIcon FontSize="14" Glyph="&#xE72B;" />
                    </Button>
                </Grid>

                <Border
                    x:Name="HeroSection"
                    Grid.Row="1"
                    Padding="40,8,40,28"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                x:Name="HeroIconBorder"
                                Width="80"
                                Height="80"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="16">
                                <Grid>
                                    <Image
                                        x:Name="HeroIconImage"
                                        Width="52"
                                        Height="52"
                                        Stretch="Uniform"
                                        Visibility="Collapsed" />
                                    <FontIcon
                                        x:Name="HeroIconGlyph"
                                        FontSize="36"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <TextBlock
                                    x:Name="HeroTitle"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock
                                        x:Name="HeroCategory"
                                        FontSize="14"
                                        Opacity="0.68" />
                                    <Border
                                        x:Name="HeroExtBadge"
                                        Padding="8,2"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="4"
                                        Visibility="Collapsed">
                                        <TextBlock
                                            x:Name="HeroExtText"
                                            FontSize="11"
                                            FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ComboBox
                                    x:Name="ArchComboBox"
                                    MinWidth="80"
                                    Padding="8,4"
                                    FontSize="13"
                                    SelectionChanged="ArchComboBox_SelectionChanged"
                                    Visibility="Collapsed">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="13" Text="{Binding DisplayText}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button
                                    x:Name="FavoriteButton"
                                    Width="40"
                                    Height="40"
                                    Padding="0"
                                    Click="FavoriteButton_Click"
                                    ToolTipService.ToolTip="收藏">
                                    <FontIcon x:Name="FavoriteIcon" FontSize="16" />
                                </Button>
                                <Button
                                    x:Name="AdminButton"
                                    Height="40"
                                    Padding="14,0"
                                    Click="AdminButton_Click"
                                    ToolTipService.ToolTip="以管理员身份运行">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE7EF;" />
                                        <TextBlock Text="管理员" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="LaunchButton"
                                    Height="40"
                                    Padding="20,0"
                                    Click="LaunchButton_Click"
                                    Style="{ThemeResource AccentButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE768;" />
                                        <TextBlock x:Name="LaunchButtonText" Text="打开" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2">
                    <StackPanel Padding="40,28,40,40" Spacing="28">
                        <Grid ColumnSpacing="40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="320" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="20">
                                <StackPanel Spacing="6">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Opacity="0.52"
                                        Text="介绍" />
                                    <TextBlock
                                        x:Name="DescriptionText"
                                        FontSize="15"
                                        LineHeight="24"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel x:Name="ReadmeSection" Spacing="6" Visibility="Collapsed">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Opacity="0.52"
                                        Text="说明文档" />
                                    <Border
                                        Padding="16"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <ScrollViewer
                                            x:Name="ReadmeScrollViewer"
                                            MaxHeight="280"
                                            VerticalScrollBarVisibility="Auto">
                                            <TextBlock
                                                x:Name="ReadmeText"
                                                FontSize="13"
                                                LineHeight="20"
                                                Opacity="0.82"
                                                TextWrapping="Wrap" />
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <Border
                                Grid.Column="1"
                                Padding="20"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="12">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Opacity="0.52"
                                        Text="详细信息" />

                                    <StackPanel Spacing="8">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon
                                                FontSize="12"
                                                Glyph="&#xE946;"
                                                Opacity="0.52" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock FontSize="11" Opacity="0.52" Text="发布者" />
                                                <TextBlock
                                                    x:Name="PublisherText"
                                                    FontSize="13"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon
                                                FontSize="12"
                                                Glyph="&#xE922;"
                                                Opacity="0.52" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock FontSize="11" Opacity="0.52" Text="版本" />
                                                <TextBlock x:Name="VersionText" FontSize="13" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon
                                                FontSize="12"
                                                Glyph="&#xE8E5;"
                                                Opacity="0.52" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock FontSize="11" Opacity="0.52" Text="文件类型" />
                                                <TextBlock x:Name="FileTypeText" FontSize="13" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon
                                                FontSize="12"
                                                Glyph="&#xE8B7;"
                                                Opacity="0.52" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock FontSize="11" Opacity="0.52" Text="路径" />
                                                <TextBlock
                                                    x:Name="PathText"
                                                    FontSize="12"
                                                    IsTextSelectionEnabled="True"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <Button
                                        x:Name="DesktopShortcutButton"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="DesktopShortcutButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="12" Glyph="&#xE8BD;" />
                                            <TextBlock Text="发送到桌面快捷方式" />
                                        </StackPanel>
                                    </Button>

                                    <Button
                                        x:Name="OpenFolderButton"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="OpenFolderButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="12" Glyph="&#xE838;" />
                                            <TextBlock Text="打开所在文件夹" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <InfoBar
                            x:Name="StatusBar"
                            HorizontalAlignment="Left"
                            IsClosable="True"
                            IsOpen="False" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
