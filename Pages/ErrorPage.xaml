<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.ErrorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="48" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            MaxWidth="640"
            Spacing="24">

            <Image
                x:Name="ErrorGifImage"
                HorizontalAlignment="Center"
                Width="180"
                Height="180"
                Stretch="UniformToFill" />

            <StackPanel HorizontalAlignment="Center" Spacing="6">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="出现了意外错误" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Opacity="0.68"
                    Text="应用遇到了一个未处理的异常，你可以复制详细信息并提交 Issue。"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Opacity="0.78"
                            Text="异常详情" />
                        <Button
                            x:Name="CopyButton"
                            HorizontalAlignment="Right"
                            Padding="10,4"
                            Click="CopyButton_Click"
                            ToolTipService.ToolTip="复制到剪贴板">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                                <TextBlock FontSize="12" Text="复制" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <ScrollViewer MaxHeight="200">
                        <TextBlock
                            x:Name="ErrorText"
                            FontFamily="Cascadia Code, Consolas"
                            FontSize="13"
                            Opacity="0.82"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <StackPanel
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <Button
                    x:Name="ReportButton"
                    Padding="20,10"
                    Click="ReportButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE8F1;" />
                        <TextBlock Text="提交 GitHub Issue" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="RestartButton"
                    Padding="20,10"
                    Click="RestartButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="重启应用" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>