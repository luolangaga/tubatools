<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TubaWinUi3.Pages.CustomToolManagerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Padding="24,20,24,12" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                FontSize="24"
                FontWeight="SemiBold"
                VerticalAlignment="Center"
                Text="自定义工具管理" />
            <Button
                x:Name="CloseButton"
                Grid.Column="1"
                Click="CloseButton_Click"
                Content="关闭" />
        </Grid>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            Padding="24,0,24,0">
            <StackPanel
                x:Name="CategoryPanel"
                Spacing="8" />
        </ScrollViewer>

        <Border
            Grid.Row="2"
            Padding="24,12,24,20"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Click="AddCategoryButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE710;" />
                        <TextBlock Text="新建分类" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Click="ImportToolButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE8E5;" />
                        <TextBlock Text="导入工具" />
                    </StackPanel>
                </Button>
                <TextBlock
                    x:Name="StatusText"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Opacity="0.68"
                    FontSize="12"
                    TextWrapping="Wrap"
                    MaxWidth="400" />
            </Grid>
        </Border>
    </Grid>
</Window>
