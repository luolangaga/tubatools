<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TubaWinUi3.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:NullToVisibilityConverter x:Key="NullToCollapse" />
        <local:HasAlternatesToVisibilityConverter x:Key="HasAlternatesToVis" />
        <local:NoAlternatesToVisibilityConverter x:Key="NoAlternatesToVis" />
        <local:ArchOptionsCountConverterFav x:Key="ArchOptionsCountConverter" />
        <local:HistoryCountToVisibilityConverter x:Key="HistoryCountToVis" />
        <Style x:Key="FavCardStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="HistoryCardStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="28,18,28,24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="30"
                    FontWeight="SemiBold"
                    Text="常用" />
                <TextBlock
                    x:Name="SubtitleText"
                    Opacity="0.72"
                    Text="你收藏的工具会显示在这里。" />
            </StackPanel>

            <Border
                Padding="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="44"
                        Height="44"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="8">
                        <FontIcon
                            FontSize="22"
                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                            Glyph="&#xE735;" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="我的收藏" />
                        <TextBlock
                            x:Name="ToolCountText"
                            Opacity="0.68" />
                    </StackPanel>

                    <Button
                        x:Name="ClearAllButton"
                        Grid.Column="2"
                        Padding="12,6"
                        Click="ClearAllButton_Click"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="12" Glyph="&#xE74D;" />
                            <TextBlock Text="清空全部" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <GridView
                x:Name="ToolsGrid"
                IsItemClickEnabled="True"
                ItemClick="ToolsGrid_ItemClick"
                ItemContainerStyle="{StaticResource FavCardStyle}"
                SelectionMode="None"
                SizeChanged="ToolsGrid_SizeChanged">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="16"
                            MinHeight="220"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                            <Grid RowSpacing="7">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="52" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="48"
                                        Height="48"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="8">
                                        <Grid>
                                            <Image
                                                Width="32"
                                                Height="32"
                                                Source="{Binding IconPath}"
                                                Stretch="Uniform"
                                                Visibility="{Binding IconPath, Converter={StaticResource NullToCollapse}}" />
                                            <FontIcon
                                                FontSize="24"
                                                Glyph="{Binding IconGlyph}"
                                                Visibility="{Binding IconGlyph, Converter={StaticResource NullToCollapse}}" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="3">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            MaxLines="1"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="12"
                                            Opacity="0.64"
                                            Text="{Binding Category}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock
                                    Grid.Row="1"
                                    MaxLines="2"
                                    Opacity="0.72"
                                    Text="{Binding Description}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="Wrap" />

                                <Grid Grid.Row="2" ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Padding="8,3"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="6">
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Text="{Binding Extension}" />
                                    </Border>
                                    <ComboBox
                                        Grid.Column="1"
                                        Width="78"
                                        MinHeight="24"
                                        Padding="6,1"
                                        FontSize="12"
                                        ItemsSource="{Binding ArchOptions}"
                                        SelectedItem="{Binding SelectedArch, Mode=TwoWay}"
                                        Visibility="{Binding ArchOptions.Count, Converter={StaticResource ArchOptionsCountConverter}}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontSize="12" Text="{Binding DisplayText}" TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>

                                <Grid Grid.Row="3" ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Padding="0"
                                        Click="SendToDesktopButton_Click"
                                        ToolTipService.ToolTip="发送到桌面快捷方式">
                                        <FontIcon FontSize="12" Glyph="&#xE8BD;" />
                                    </Button>
                                    <Button
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Padding="0"
                                        Click="RunAsAdminButton_Click"
                                        ToolTipService.ToolTip="以管理员身份运行">
                                        <FontIcon FontSize="12" Glyph="&#xE7EF;" />
                                    </Button>
                                    <Button
                                        Grid.Column="2"
                                        MinWidth="88"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Padding="10,4"
                                        Click="LaunchButton_Click">
                                        <TextBlock
                                            Text="{Binding LaunchButtonText}"
                                            TextAlignment="Center"
                                            TextTrimming="CharacterEllipsis" />
                                    </Button>
                                    <Button
                                        Grid.Column="3"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Padding="0"
                                        Click="RemoveFavoriteButton_Click"
                                        ToolTipService.ToolTip="取消收藏">
                                        <FontIcon FontSize="12" Glyph="&#xE74D;" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <StackPanel
                x:Name="EmptyState"
                HorizontalAlignment="Center"
                Spacing="12"
                Visibility="Collapsed">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="48"
                    Glyph="&#xE735;"
                    Opacity="0.3" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="18"
                    Opacity="0.52"
                    Text="还没有收藏的工具" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.42"
                    Text="在全部页面点击星标按钮即可收藏" />
            </StackPanel>

            <StackPanel
                x:Name="HistorySection"
                Spacing="10"
                Visibility="Collapsed">
                <StackPanel Spacing="2">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="最近使用" />
                    <TextBlock
                        Opacity="0.6"
                        FontSize="13"
                        Text="最近打开过的工具" />
                </StackPanel>
                <GridView
                    x:Name="HistoryGrid"
                    IsItemClickEnabled="True"
                    ItemClick="HistoryGrid_ItemClick"
                    ItemContainerStyle="{StaticResource HistoryCardStyle}"
                    SelectionMode="None"
                    SizeChanged="HistoryGrid_SizeChanged">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="8,10,8,6"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                ToolTipService.ToolTip="{Binding Description}">
                                <StackPanel HorizontalAlignment="Center" Spacing="6">
                                    <Border
                                        Width="48"
                                        Height="48"
                                        HorizontalAlignment="Center"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="10">
                                        <Grid>
                                            <Image
                                                Width="36"
                                                Height="36"
                                                Source="{Binding IconPath}"
                                                Stretch="Uniform"
                                                Visibility="{Binding IconPath, Converter={StaticResource NullToCollapse}}" />
                                            <FontIcon
                                                FontSize="24"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Glyph="{Binding IconGlyph}"
                                                Visibility="{Binding IconGlyph, Converter={StaticResource NullToCollapse}}" />
                                        </Grid>
                                    </Border>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        MaxLines="2"
                                        Text="{Binding Name}"
                                        TextAlignment="Center"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap"
                                        Width="84" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

            <TeachingTip
                x:Name="ToolDetailTip"
                CloseButtonContent="关闭"
                PreferredPlacement="Right">
                <StackPanel MaxWidth="420" Spacing="8">
                    <TextBlock x:Name="DetailDescriptionText" TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailPublisherText" Opacity="0.72" TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailVersionText" Opacity="0.72" TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailPathText" Opacity="0.72" TextWrapping="Wrap" />
                </StackPanel>
            </TeachingTip>

            <InfoBar
                x:Name="StatusBar"
                HorizontalAlignment="Right"
                IsClosable="True"
                IsOpen="False" />
        </StackPanel>
    </ScrollViewer>
</Page>
