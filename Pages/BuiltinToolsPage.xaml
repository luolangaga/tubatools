<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.BuiltinToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="BuiltinCardStyle" TargetType="GridViewItem">
            <Setter Property="MinWidth" Value="236" />
            <Setter Property="MaxWidth" Value="300" />
            <Setter Property="MinHeight" Value="140" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid Padding="28,18,28,24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock
                FontSize="30"
                FontWeight="SemiBold"
                Text="内置" />
            <TextBlock
                Opacity="0.72"
                Text="无需外部文件，直接使用的系统工具集。" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Padding="18"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="44"
                    Height="44"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="8">
                    <FontIcon
                        FontSize="22"
                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                        Glyph="&#xE90F;" />
                </Border>

                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="内置工具" />
                    <TextBlock
                        x:Name="ToolCountText"
                        Opacity="0.68" />
                </StackPanel>

                <ComboBox
                    x:Name="CategoryFilter"
                    Grid.Column="2"
                    MinWidth="140"
                    SelectionChanged="CategoryFilter_SelectionChanged" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <GridView
                x:Name="ToolsGrid"
                IsItemClickEnabled="True"
                ItemClick="ToolsGrid_ItemClick"
                ItemContainerStyle="{StaticResource BuiltinCardStyle}"
                SelectionMode="None">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="42"
                                        Height="42"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="8">
                                        <FontIcon
                                            FontSize="20"
                                            Glyph="{Binding Glyph}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="3">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="12"
                                            Opacity="0.64"
                                            Text="{Binding Category}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock
                                    Grid.Row="1"
                                    MaxLines="2"
                                    Opacity="0.72"
                                    Text="{Binding Description}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="Wrap" />

                                <Grid Grid.Row="2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        HorizontalAlignment="Left"
                                        Padding="8,3"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="6">
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Text="{Binding KindText}" />
                                    </Border>
                                    <Button
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        Padding="10,4"
                                        Click="RunButton_Click"
                                        Content="运行" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <InfoBar
                x:Name="StatusBar"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                IsClosable="True"
                IsOpen="False" />
        </Grid>
    </Grid>
</Page>